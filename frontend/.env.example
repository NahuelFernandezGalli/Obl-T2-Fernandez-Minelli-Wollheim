VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_cloud_project_id_here
VITE_JOBMARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
# Bloque donde se desplegó el contrato (para leer eventos sin escanear toda la cadena).
# Opcional: si no se setea, usa el default del código. Solo cambiarlo al redesplegar.
# VITE_JOBMARKETPLACE_DEPLOY_BLOCK=11137384

# IPFS Si se setea el JWT de Pinata, los deliverables se suben a IPFS
# y el evaluador los ve desde cualquier dispositivo. Si no, se usa localStorage (modo híbrido).
# VITE_PINATA_JWT=eyJ...tu_jwt_de_pinata
# VITE_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
